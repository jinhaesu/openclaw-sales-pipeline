{
  "vendor_name": "GS25",
  "strategy": "browser_download",
  "browser_actions": [
    {
      "type": "goto"
    },
    {
      "type": "eval",
      "expression": "() => { try { if (typeof closePopEdge === 'function') closePopEdge(); if (typeof closePop === 'function') closePop(); } catch (e) {} }"
    },
    {
      "type": "fill_credential",
      "name": "uid",
      "source": "login_id"
    },
    {
      "type": "fill_credential",
      "name": "empid",
      "source": "login_id_2"
    },
    {
      "type": "fill_credential",
      "name": "bmbh",
      "source": "password"
    },
    {
      "type": "click_alt",
      "alt": "LOGIN"
    },
    {
      "type": "wait_for_timeout",
      "ms": 2500
    },
    {
      "type": "click_text",
      "text": "부가정보"
    },
    {
      "type": "wait_for_timeout",
      "ms": 2500
    },
    {
      "type": "click_text_in_frame",
      "frame_url_contains": "MainFrame.jsp",
      "text": "납품정보"
    },
    {
      "type": "wait_for_timeout",
      "ms": 2000
    },
    {
      "type": "assert_frame_url_contains",
      "url_contains": "NaPeriod.jsp"
    },
    {
      "type": "screenshot",
      "path": "na_period.png"
    },
    {
      "type": "note",
      "message": "부가정보 > 납품정보 > 기간별 화면까지 도달한 뒤 다운로드 selector를 추가한다."
    }
  ],
  "notes": [
    "실화면 기준 로그인 자동화 적용",
    "부가정보 > 납품정보 > 기간별 프레임 진입 확인"
  ]
}
