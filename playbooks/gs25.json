{
  "vendor_name": "GS25",
  "strategy": "browser_download",
  "browser_actions": [
    {
      "type": "goto"
    },
    {
      "type": "eval",
      "expression": "() => { try { if (typeof closePopEdge === 'function') closePopEdge(); if (typeof closePop === 'function') closePop(); } catch (e) {} }"
    },
    {
      "type": "fill_credential",
      "name": "uid",
      "source": "login_id"
    },
    {
      "type": "fill_credential",
      "name": "empid",
      "source": "login_id_2"
    },
    {
      "type": "fill_credential",
      "name": "bmbh",
      "source": "password"
    },
    {
      "type": "click_alt",
      "alt": "LOGIN"
    },
    {
      "type": "wait_for_timeout",
      "ms": 2000
    },
    {
      "type": "screenshot",
      "path": "after_login.png"
    },
    {
      "type": "note",
      "message": "로그인 후 프레임 구조와 메뉴 selector를 다음 단계에서 고정한다."
    }
  ],
  "notes": [
    "실화면 기준 로그인 자동화 1차 적용",
    "로그인 후 메뉴 경로는 후속 프레임 탐색 필요"
  ]
}
