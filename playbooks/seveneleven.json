{
  "vendor_name": "세븐일레븐",
  "strategy": "browser_verified",
  "browser_actions": [
    {
      "type": "goto"
    },
    {
      "type": "fill_selector",
      "selector": "#login-groupId",
      "source": "client_id"
    },
    {
      "type": "fill_selector",
      "selector": "#login-userId",
      "source": "id"
    },
    {
      "type": "fill_selector",
      "selector": "#login-password",
      "source": "pw"
    },
    {
      "type": "wait_for_timeout",
      "ms": 1000
    },
    {
      "type": "screenshot",
      "path": "preauth_ready.png"
    },
    {
      "type": "note",
      "message": "인증 전 단계까지 자동 입력 완료. 휴대폰 인증 후 세션이 저장되면 discovery에서 post-auth 메뉴를 재사용한다."
    }
  ],
  "notes": [
    "휴대폰 인증 채널",
    "세션 유지가 가장 중요하다.",
    "pre-auth와 post-auth discovery를 분리 운영한다."
  ],
  "metadata": {
    "discovery_split": {
      "pre_auth_complete": true,
      "post_auth_requires": "sms_code_or_existing_session"
    }
  }
}
